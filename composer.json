{
    "version": "1.0.0",
    "name": "kreitje/uddf-generator",
    "description": "Generate UDDF (Universal Dive Data Format) XML files using typed PHP objects",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-dom": "*"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit tests"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kreitje\\UddfGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kreitje\\UddfGenerator\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
